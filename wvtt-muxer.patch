+static int mov_create_wvtt_sample(AVPacket *pkt)
+{
+    AVBufferRef *buf;
+    uint8_t *p;
+    int new_size;
+    const uint8_t *iden = NULL, *sttg = NULL;
+    size_t iden_size = 0, sttg_size = 0;
+
+    if (pkt->size == 0) {
+        new_size = 8;
+    } else {
+        iden = av_packet_get_side_data(pkt, AV_PKT_DATA_WEBVTT_IDENTIFIER,
+                                       &iden_size);
+        sttg = av_packet_get_side_data(pkt, AV_PKT_DATA_WEBVTT_SETTINGS,
+                                       &sttg_size);
+        new_size = 8 + 8 + pkt->size
+                 + (iden_size ? 8 + (int)iden_size : 0)
+                 + (sttg_size ? 8 + (int)sttg_size : 0);
+    }
+
+    buf = av_buffer_alloc(new_size + AV_INPUT_BUFFER_PADDING_SIZE);
+    if (!buf)
+        return AVERROR(ENOMEM);
+    memset(buf->data + new_size, 0, AV_INPUT_BUFFER_PADDING_SIZE);
+
+    p = buf->data;
+    if (pkt->size == 0) {
+        AV_WB32(p,     8);
+        AV_WL32(p + 4, MKTAG('v','t','t','e'));
+    } else {
+        AV_WB32(p,     new_size);
+        AV_WL32(p + 4, MKTAG('v','t','t','c'));
+        p += 8;
+        if (iden_size) {
+            AV_WB32(p,     8 + (int)iden_size);
+            AV_WL32(p + 4, MKTAG('i','d','e','n'));
+            memcpy(p + 8, iden, iden_size);
+            p += 8 + iden_size;
+        }
+        if (sttg_size) {
+            AV_WB32(p,     8 + (int)sttg_size);
+            AV_WL32(p + 4, MKTAG('s','t','t','g'));
+            memcpy(p + 8, sttg, sttg_size);
+            p += 8 + sttg_size;
+        }
+        AV_WB32(p,     8 + pkt->size);
+        AV_WL32(p + 4, MKTAG('p','a','y','l'));
+        memcpy(p + 8, pkt->data, pkt->size);
+    }
+
+    av_buffer_unref(&pkt->buf);
+    pkt->buf  = buf;
+    pkt->data = buf->data;
+    pkt->size = new_size;
+    return 0;
+}
